        <mapper resource="mapper/user/UserMapper.xml"/>
        <mapper resource="mapper/vehicle/VehicleMapper.xml"/>
        <mapper resource="mapper/shop/ShopMapper.xml"/>
        <mapper resource="mapper/booking/BookingMapper.xml"/>
        <mapper resource="mapper/maintenance/MaintenanceMapper.xml"/>
        <mapper resource="mapper/payment/PaymentMapper.xml"/>
        <mapper resource="mapper/notification/NotificationMapper.xml"/>
    </mappers>
    -->
</configuration>
