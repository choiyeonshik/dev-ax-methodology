{
	"info": {
		"_postman_id": "car-center-api-test",
		"name": "Car Center API Collection",
		"description": "자동차 센터 관리 시스템 API 테스트 컬렉션",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api",
			"type": "string"
		},
		{
			"key": "jwtToken",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "기본 헬스체크",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "애플리케이션의 기본 상태를 확인합니다."
					},
					"response": []
				},
				{
					"name": "핑 체크",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health/ping",
							"host": ["{{baseUrl}}"],
							"path": ["health", "ping"]
						},
						"description": "간단한 응답성 확인을 위한 핑 엔드포인트입니다."
					},
					"response": []
				},
				{
					"name": "애플리케이션 정보",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health/info",
							"host": ["{{baseUrl}}"],
							"path": ["health", "info"]
						},
						"description": "애플리케이션의 기본 정보를 반환합니다."
					},
					"response": []
				},
				{
					"name": "Actuator 헬스체크",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/actuator/health",
							"host": ["{{baseUrl}}"],
							"path": ["actuator", "health"]
						},
						"description": "Spring Boot Actuator 헬스체크 엔드포인트입니다."
					},
					"response": []
				}
			]
		}
	]
}
