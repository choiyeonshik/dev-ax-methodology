{
	"info": {
		"_postman_id": "car-center-auth-complete",
		"name": "Car Center - 사용자 등록 및 인증 테스트",
		"description": "사용자 등록, 로그인, 프로필 관리를 위한 완전한 테스트 컬렉션",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api",
			"type": "string"
		},
		{
			"key": "authUrl",
			"value": "{{baseUrl}}/auth",
			"type": "string"
		},
		{
			"key": "usersUrl",
			"value": "{{baseUrl}}/users",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "testUsername",
			"value": "testuser{{$timestamp}}",
			"type": "string"
		},
		{
			"key": "testEmail",
			"value": "test{{$timestamp}}@example.com",
			"type": "string"
		},
		{
			"key": "testPassword",
			"value": "TestPassword123!",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. 사전 검증 (Pre-validation)",
			"item": [
				{
					"name": "애플리케이션 상태 확인",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "애플리케이션이 정상적으로 실행되고 있는지 확인합니다."
					},
					"response": []
				},
				{
					"name": "비밀번호 정책 검증",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"password\": \"{{testPassword}}\"\n}"
						},
						"url": {
							"raw": "{{authUrl}}/validate-password",
							"host": ["{{authUrl}}"],
							"path": ["validate-password"]
						},
						"description": "사용할 비밀번호가 정책에 맞는지 확인합니다."
					},
					"response": []
				}
			]
		},
		{
			"name": "2. 중복 확인 (Duplication Check)",
			"item": [
				{
					"name": "사용자명 중복 확인",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{authUrl}}/check-username?username={{testUsername}}",
							"host": ["{{authUrl}}"],
							"path": ["check-username"],
							"query": [
								{
									"key": "username",
									"value": "{{testUsername}}"
								}
							]
						},
						"description": "사용할 사용자명이 이미 존재하는지 확인합니다."
					},
					"response": []
				},
				{
					"name": "이메일 중복 확인",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{authUrl}}/check-email?email={{testEmail}}",
							"host": ["{{authUrl}}"],
							"path": ["check-email"],
							"query": [
								{
									"key": "email",
									"value": "{{testEmail}}"
								}
							]
						},
						"description": "사용할 이메일이 이미 존재하는지 확인합니다."
					},
					"response": []
				}
			]
		},
		{
			"name": "3. 회원가입 (Registration)",
			"item": [
				{
					"name": "사용자 등록",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"회원가입 성공\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"응답 데이터 검증\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"    pm.expect(jsonData.data).to.have.property('username');",
									"    pm.expect(jsonData.data).to.have.property('email');",
									"    pm.expect(jsonData.data).to.have.property('name');",
									"    pm.expect(jsonData.data.active).to.be.true;",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\",\n  \"email\": \"{{testEmail}}\",\n  \"name\": \"테스트 사용자\",\n  \"phoneNumber\": \"010-1234-5678\"\n}"
						},
						"url": {
							"raw": "{{authUrl}}/register",
							"host": ["{{authUrl}}"],
							"path": ["register"]
						},
						"description": "새로운 사용자 계정을 생성합니다."
					},
					"response": []
				},
				{
					"name": "중복 사용자명으로 등록 시도 (실패 케이스)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"중복 사용자명으로 등록 실패\", function () {",
									"    pm.response.to.have.status(409);",
									"});",
									"",
									"pm.test(\"에러 메시지 검증\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.false;",
									"    pm.expect(jsonData.message).to.include('사용자명');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\",\n  \"email\": \"different{{$randomInt}}@example.com\",\n  \"name\": \"중복 테스트 사용자\",\n  \"phoneNumber\": \"010-9999-9999\"\n}"
						},
						"url": {
							"raw": "{{authUrl}}/register",
							"host": ["{{authUrl}}"],
							"path": ["register"]
						},
						"description": "이미 존재하는 사용자명으로 등록을 시도하여 실패하는지 확인합니다."
					},
					"response": []
				},
				{
					"name": "약한 비밀번호로 등록 시도 (실패 케이스)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"약한 비밀번호로 등록 실패\", function () {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test(\"비밀번호 정책 에러 메시지 검증\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.false;",
									"    pm.expect(jsonData.message).to.include('비밀번호');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"weakpwd{{$randomInt}}\",\n  \"password\": \"123\",\n  \"email\": \"weakpwd{{$randomInt}}@example.com\",\n  \"name\": \"약한 비밀번호 테스트\",\n  \"phoneNumber\": \"010-1111-1111\"\n}"
						},
						"url": {
							"raw": "{{authUrl}}/register",
							"host": ["{{authUrl}}"],
							"path": ["register"]
						},
						"description": "정책에 맞지 않는 약한 비밀번호로 등록을 시도하여 실패하는지 확인합니다."
					},
					"response": []
				}
			]
		},
		{
			"name": "4. 로그인 (Authentication)",
			"item": [
				{
					"name": "사용자 로그인",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"로그인 성공\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"토큰 발급 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"    pm.expect(jsonData.data).to.have.property('accessToken');",
									"    pm.expect(jsonData.data).to.have.property('refreshToken');",
									"    pm.expect(jsonData.data).to.have.property('tokenType');",
									"    pm.expect(jsonData.data.tokenType).to.eql('Bearer');",
									"    ",
									"    // 토큰을 변수에 저장",
									"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
									"});",
									"",
									"pm.test(\"사용자 정보 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.user).to.have.property('username');",
									"    pm.expect(jsonData.data.user).to.have.property('email');",
									"    pm.expect(jsonData.data.user.active).to.be.true;",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\"\n}"
						},
						"url": {
							"raw": "{{authUrl}}/login",
							"host": ["{{authUrl}}"],
							"path": ["login"]
						},
						"description": "등록한 사용자 계정으로 로그인을 시도합니다."
					},
					"response": []
				},
				{
					"name": "잘못된 비밀번호로 로그인 시도 (실패 케이스)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"잘못된 비밀번호로 로그인 실패\", function () {",
									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test(\"인증 실패 메시지 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.false;",
									"    pm.expect(jsonData.message).to.include('인증');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"WrongPassword123!\"\n}"
						},
						"url": {
							"raw": "{{authUrl}}/login",
							"host": ["{{authUrl}}"],
							"path": ["login"]
						},
						"description": "잘못된 비밀번호로 로그인을 시도하여 실패하는지 확인합니다."
					},
					"response": []
				},
				{
					"name": "존재하지 않는 사용자로 로그인 시도 (실패 케이스)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"존재하지 않는 사용자로 로그인 실패\", function () {",
									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test(\"인증 실패 메시지 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.false;",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"nonexistentuser{{$randomInt}}\",\n  \"password\": \"{{testPassword}}\"\n}"
						},
						"url": {
							"raw": "{{authUrl}}/login",
							"host": ["{{authUrl}}"],
							"path": ["login"]
						},
						"description": "존재하지 않는 사용자명으로 로그인을 시도하여 실패하는지 확인합니다."
					},
					"response": []
				}
			]
		},
		{
			"name": "5. 인증된 API 테스트 (Authenticated APIs)",
			"item": [
				{
					"name": "내 프로필 조회",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"프로필 조회 성공\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"프로필 정보 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"    pm.expect(jsonData.data).to.have.property('username');",
									"    pm.expect(jsonData.data).to.have.property('email');",
									"    pm.expect(jsonData.data).to.have.property('name');",
									"    pm.expect(jsonData.data.username).to.eql(pm.collectionVariables.get('testUsername'));",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{usersUrl}}/profile",
							"host": ["{{usersUrl}}"],
							"path": ["profile"]
						},
						"description": "로그인한 사용자의 프로필 정보를 조회합니다."
					},
					"response": []
				},
				{
					"name": "내 프로필 수정",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"프로필 수정 성공\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"수정된 정보 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"    pm.expect(jsonData.data.name).to.eql('수정된 테스트 사용자');",
									"    pm.expect(jsonData.data.phoneNumber).to.eql('010-9999-8888');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"수정된 테스트 사용자\",\n  \"phoneNumber\": \"010-9999-8888\"\n}"
						},
						"url": {
							"raw": "{{usersUrl}}/profile",
							"host": ["{{usersUrl}}"],
							"path": ["profile"]
						},
						"description": "로그인한 사용자의 프로필 정보를 수정합니다."
					},
					"response": []
				},
				{
					"name": "인증 없이 프로필 조회 시도 (실패 케이스)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"인증 없이 프로필 조회 실패\", function () {",
									"    pm.response.to.have.status(401);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{usersUrl}}/profile",
							"host": ["{{usersUrl}}"],
							"path": ["profile"]
						},
						"description": "인증 토큰 없이 프로필 조회를 시도하여 실패하는지 확인합니다."
					},
					"response": []
				}
			]
		},
		{
			"name": "6. 토큰 관리 (Token Management)",
			"item": [
				{
					"name": "토큰 갱신",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"토큰 갱신 성공\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"새로운 토큰 발급 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"    pm.expect(jsonData.data).to.have.property('accessToken');",
									"    pm.expect(jsonData.data).to.have.property('refreshToken');",
									"    ",
									"    // 새로운 토큰으로 업데이트",
									"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{authUrl}}/refresh?refreshToken={{refreshToken}}",
							"host": ["{{authUrl}}"],
							"path": ["refresh"],
							"query": [
								{
									"key": "refreshToken",
									"value": "{{refreshToken}}"
								}
							]
						},
						"description": "Refresh Token을 사용하여 새로운 Access Token을 발급받습니다."
					},
					"response": []
				},
				{
					"name": "로그아웃",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"로그아웃 성공\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"로그아웃 응답 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"// 토큰 변수 초기화",
									"pm.collectionVariables.set('accessToken', '');",
									"pm.collectionVariables.set('refreshToken', '');"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{authUrl}}/logout?refreshToken={{refreshToken}}",
							"host": ["{{authUrl}}"],
							"path": ["logout"],
							"query": [
								{
									"key": "refreshToken",
									"value": "{{refreshToken}}"
								}
							]
						},
						"description": "현재 세션에서 로그아웃하고 토큰을 무효화합니다."
					},
					"response": []
				},
				{
					"name": "로그아웃 후 프로필 조회 시도 (실패 케이스)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"로그아웃 후 프로필 조회 실패\", function () {",
									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test(\"블랙리스트된 토큰으로 접근 차단 확인\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.false;",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
