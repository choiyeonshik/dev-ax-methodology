					"// 고정된 테스트 데이터 생성 (세션 동안 일관성 유지)",
					"if (!pm.collectionVariables.get('testUsername')) {",
					"    const timestamp = Date.now();",
					"    pm.collectionVariables.set('testUsername', 'testuser' + timestamp);",
					"    pm.collectionVariables.set('testEmail', 'test' + timestamp + '@example.com');",
					"    console.log('Test user initialized:', pm.collectionVariables.get('testUsername'));",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// 전역 테스트 - 모든 요청에 적용",
