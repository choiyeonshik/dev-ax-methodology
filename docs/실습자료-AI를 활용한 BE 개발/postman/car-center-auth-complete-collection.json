						"url": {
							"raw": "{{usersUrl}}/profile",
							"host": ["{{usersUrl}}"],
							"path": ["profile"]
						},
						"description": "로그아웃 후 무효화된 토큰으로 프로필 조회를 시도하여 실패하는지 확인합니다."
					},
					"response": []
				}
			]
